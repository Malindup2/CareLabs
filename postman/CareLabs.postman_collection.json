		{
			"name": "Payment Service",
			"item": [
				{
					"name": "Initiate Checkout",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData && jsonData.orderId) {",
									"  pm.environment.set(\"orderId\", jsonData.orderId);",
									"}",
									"if (jsonData && jsonData.amount) {",
									"  pm.environment.set(\"paymentAmount\", String(jsonData.amount));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\r\n    \"appointmentId\": \"{{appointmentId}}\",\r\n    \"patientFirstName\": \"John\",\r\n    \"patientLastName\": \"Doe\",\r\n    \"patientEmail\": \"john@example.com\",\r\n    \"patientPhone\": \"0712345678\",\r\n    \"patientCity\": \"Colombo\"\r\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/payments/initiate",
					{
						"name": "Webhook: Payment Notify",
						"event": [
							{
								"listen": "prerequest",
								"script": {
									"exec": [
										"var merchantId = pm.environment.get('payhereMerchantId');",
										"var merchantSecret = pm.environment.get('payhereMerchantSecret');",
										"var orderId = pm.environment.get('orderId');",
										"var amount = pm.environment.get('paymentAmount') || '1500.00';",
										"var currency = pm.environment.get('payhereCurrency') || 'LKR';",
										"var statusCode = pm.environment.get('paymentStatusCode') || '2';",
										"var paymentId = pm.environment.get('paymentId') || 'PAYHERE_TEST_TXN';",
										"var method = pm.environment.get('paymentMethod') || 'CARD';",
										"var secretHash = CryptoJS.MD5(merchantSecret).toString(CryptoJS.enc.Hex).toUpperCase();",
										"var md5sig = CryptoJS.MD5(merchantId + orderId + amount + currency + statusCode + secretHash).toString(CryptoJS.enc.Hex).toUpperCase();",
										"pm.environment.set('md5sig', md5sig);",
										"pm.environment.set('paymentId', paymentId);",
										"pm.environment.set('paymentMethod', method);"
									],
									"type": "text/javascript"
								}
							}
						],
						"request": {
							"method": "POST",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/x-www-form-urlencoded"
								}
							],
							"body": {
								"mode": "urlencoded",
								"urlencoded": [
									{ "key": "merchant_id", "value": "{{payhereMerchantId}}" },
									{ "key": "order_id", "value": "{{orderId}}" },
									{ "key": "payment_id", "value": "{{paymentId}}" },
									{ "key": "payhere_amount", "value": "{{paymentAmount}}" },
									{ "key": "payhere_currency", "value": "{{payhereCurrency}}" },
									{ "key": "status_code", "value": "{{paymentStatusCode}}" },
									{ "key": "md5sig", "value": "{{md5sig}}" },
									{ "key": "method", "value": "{{paymentMethod}}" }
								]
							},
							"url": {
								"raw": "{{baseUrl}}/payments/notify",
								"host": [
									"{{baseUrl}}"
								],
								"path": [
									"payments",
									"notify"
								]
							}
						},
						"response": []
					},
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"payments",
								"initiate"
							]
						}
					},
					"response": []
				},
				{
					"name": "Verify Payment",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/payments/verify/{{orderId}}",
							"host": [
